<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Raihana Islam Ikra | Financial Analytics Portfolio</title>
    <style>
        :root {
            --primary-bg: #0f172a; /* Sleek Slate Blue-Black */
            --main-bg: #FFFFFF;
            --section-bg: #F8FAFC;
            --accent: #2563EB; /* Premium Royal Blue */
            --accent-dim: rgba(37, 99, 235, 0.08);
            --text-main: #1E293B; /* Charcoal Slate */
            --text-muted: #64748B;
            --border: #E2E8F0;
            --mint-highlight: #D1FAE5; /* Soft Mint green tag */
            --mint-text: #065F46;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        }

        body {
            background-color: var(--main-bg);
            color: var(--text-main);
            line-height: 1.7;
            -webkit-font-smoothing: antialiased;
        }

        header {
            position: fixed;
            top: 0;
            width: 100%;
            background-color: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border);
            z-index: 1000;
        }

        .nav-container {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1.2rem 2rem;
        }

        .logo {
            font-weight: 800;
            font-size: 1.3rem;
            color: var(--primary-bg);
            text-decoration: none;
            letter-spacing: -0.5px;
        }

        .logo span {
            color: var(--accent);
        }

        .nav-links {
            display: flex;
            list-style: none;
            gap: 2.5rem;
        }

        .nav-links a {
            color: var(--text-muted);
            text-decoration: none;
            font-weight: 500;
            font-size: 0.95rem;
            transition: color 0.2s ease;
        }

        .nav-links a:hover {
            color: var(--accent);
        }

        section {
            padding: 9rem 2rem 6rem 2rem;
            max-width: 1200px;
            margin: 0 auto;
        }

        /* Hero Section */
        #hero {
            display: grid;
            grid-template-columns: 1.1fr 0.9fr;
            gap: 5rem;
            align-items: center;
            min-height: 80vh;
        }

        .hero-content {
            display: flex;
            flex-direction: column;
        }

        .profile-img-container {
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .profile-img-container img {
            max-width: 360px;
            width: 100%;
            height: auto;
            border-radius: 16px;
            box-shadow: 0 25px 50px -12px rgba(15, 23, 42, 0.15);
            border: 4px solid #ffffff;
            outline: 1px solid var(--border);
        }

        .badge-welcome {
            background: var(--accent-dim);
            color: var(--accent);
            padding: 0.4rem 1rem;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 700;
            letter-spacing: 0.05em;
            width: fit-content;
            margin-bottom: 1.5rem;
            border: 1px solid rgba(37, 99, 235, 0.15);
            text-transform: uppercase;
        }

        #hero h1 {
            font-size: 3.5rem;
            line-height: 1.15;
            font-weight: 800;
            letter-spacing: -1.5px;
            color: var(--primary-bg);
            margin-bottom: 0.75rem;
        }

        .uiu-badge {
            font-size: 1.2rem;
            color: var(--text-muted);
            font-weight: 500;
            margin-bottom: 1.5rem;
        }

        .uiu-badge span {
            color: var(--accent);
            font-weight: 600;
        }

        .hero-bio {
            font-size: 1.15rem;
            color: var(--text-muted);
            margin-bottom: 2.5rem;
            max-width: 620px;
            text-align: justify;
        }

        .btn-primary {
            display: inline-block;
            background-color: var(--primary-bg);
            color: white;
            padding: 0.9rem 2.2rem;
            border-radius: 8px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s ease;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            background-color: var(--accent);
            box-shadow: 0 10px 25px rgba(37, 99, 235, 0.25);
        }

        /* Quick Contact Bar */
        .contact-row {
            display: flex;
            flex-wrap: wrap;
            gap: 1.5rem;
            margin-top: 1rem;
        }

        .contact-item {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            color: var(--text-main);
            text-decoration: none;
            font-weight: 500;
            font-size: 0.95rem;
            padding: 0.5rem 1rem;
            background: var(--section-bg);
            border: 1px solid var(--border);
            border-radius: 6px;
            transition: all 0.2s ease;
        }

        .contact-item:hover {
            border-color: var(--accent);
            background: #ffffff;
        }

        .contact-item svg {
            color: var(--accent);
            width: 18px;
            height: 18px;
        }

        /* Section Layouts */
        .section-title {
            font-size: 2.2rem;
            font-weight: 800;
            letter-spacing: -0.75px;
            margin-bottom: 3rem;
            color: var(--primary-bg);
            position: relative;
        }

        .section-title::after {
            content: '';
            display: block;
            width: 40px;
            height: 4px;
            background-color: var(--accent);
            margin-top: 0.75rem;
            border-radius: 2px;
        }

        #about {
            background-color: var(--section-bg);
            border-top: 1px solid var(--border);
            border-bottom: 1px solid var(--border);
        }

        .about-grid {
            display: grid;
            grid-template-columns: 1.2fr 0.8fr;
            gap: 5rem;
        }

        .about-text p {
            color: var(--text-muted);
            margin-bottom: 1.5rem;
            font-size: 1.1rem;
            text-align: justify;
        }

        /* Projects Framework */
        .projects-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2.5rem;
        }

        .project-card {
            background: #FFFFFF;
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 2.5rem 2rem;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .project-card:hover {
            border-color: transparent;
            transform: translateY(-5px);
            box-shadow: 0 20px 40px rgba(15, 23, 42, 0.06);
        }

        .project-tag {
            background: var(--mint-highlight);
            color: var(--mint-text);
            padding: 0.3rem 0.8rem;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            width: fit-content;
            margin-bottom: 1.5rem;
        }

        .project-meta h3 {
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--primary-bg);
            margin-bottom: 0.5rem;
            line-height: 1.3;
        }

        .project-meta p.client {
            color: var(--accent);
            font-weight: 600;
            font-size: 0.85rem;
            margin-bottom: 1.25rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .project-desc {
            color: var(--text-muted);
            font-size: 1rem;
            margin-bottom: 2rem;
            text-align: justify;
        }

        /* Metrics Data Display */
        .metrics-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem;
            margin-bottom: 1.5rem;
            background: var(--section-bg);
            padding: 1rem;
            border-radius: 8px;
            border: 1px solid var(--border);
        }

        .metric-box {
            display: flex;
            flex-direction: column;
        }

        .metric-val {
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--primary-bg);
            font-family: monospace;
        }

        .metric-label {
            font-size: 0.75rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-top: 0.1rem;
        }

        .tag-row {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .tag {
            background: var(--section-bg);
            border: 1px solid var(--border);
            padding: 0.3rem 0.6rem;
            border-radius: 4px;
            font-size: 0.75rem;
            color: var(--text-muted);
            font-weight: 500;
        }

        /* Footer Element */
        footer {
            border-top: 1px solid var(--border);
            padding: 3rem 2rem;
            text-align: center;
            color: var(--text-muted);
            font-size: 0.9rem;
            background-color: var(--section-bg);
        }

        @media (max-width: 992px) {
            #hero { grid-template-columns: 1fr; text-align: center; gap: 3rem; }
            .profile-img-container { order: -1; }
            .badge-welcome { margin: 0 auto 1.5rem auto; }
            .hero-bio { margin: 0 auto 2.5rem auto; }
            .contact-row { justify-content: center; }
            .about-grid { grid-template-columns: 1fr; gap: 3rem; }
            .projects-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
